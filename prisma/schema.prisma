generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  // Placeholder only. The real connection is provided by the libSQL driver
  // adapter (see prisma.config.ts for the CLI/schema engine, and src/lib/db.ts
  // for the runtime), which reads DATABASE_URL/TURSO_AUTH_TOKEN from the env.
  // Prisma's schema validation rejects a libsql:// URL here, so we keep a
  // static file: value that the adapter overrides.
  url          = "file:./prisma/dev.db"
  relationMode = "prisma"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  clearance    Int      @default(1)
  canPostScp   Boolean  @default(false)
  isOwner      Boolean  @default(false)
  // Co-Owner: owner-equivalent powers, held by at most one member at a time.
  // Only the seeded owner can grant or revoke it.
  isCoOwner    Boolean  @default(false)
  isAdmin      Boolean  @default(false)
  isStaff      Boolean  @default(false)
  department   String?
  // Optional alternate clearance designation shown instead of the numeric label
  // (e.g. "E5", which carries the same rank-6 / L-O5 access). Null = normal.
  designation  String?
  personalFile String   @default("")
  suspended        Boolean  @default(false)
  suspendedReason  String?
  createdAt    DateTime @default(now())

  usedInvite      InviteCode?       @relation("InviteCodeUser")
  sentMessages     Message[]         @relation("MessageSender")
  receivedMessages Message[]         @relation("MessageRecipient")
  scpFiles        ScpFile[]
  broadcasts      Broadcast[]
  incidentReports IncidentReport[]
  secureMessages  SecureMessage[]
  clearanceRequests ClearanceRequest[] @relation("ClearanceRequestUser")
  reviewedRequests  ClearanceRequest[] @relation("ClearanceRequestReviewer")
  notesAbout       MemberNote[]      @relation("MemberNoteSubject")
  notesAuthored    MemberNote[]      @relation("MemberNoteAuthor")
  auditEntries     AuditLog[]        @relation("AuditActor")
  attachments      Attachment[]      @relation("AttachmentUploader")
  revisions        Revision[]        @relation("RevisionEditor")
  createdInvites   InviteCode[]      @relation("InviteCodeCreator")
  inviteRedemptions InviteRedemption[] @relation("InviteRedemptionUser")
  notifications      Notification[]      @relation("NotificationRecipient")
  infractionsAbout   MemberInfraction[]  @relation("InfractionSubject")
  infractionsIssued  MemberInfraction[]  @relation("InfractionIssuer")
}

// In-app alert surfaced by the header bell. Deliberately generic across
// triggers (new message, @mention, infraction filed) — `type` and `link`
// tell the UI what happened and where clicking it should go.
model Notification {
  id        String   @id @default(cuid())
  // "message" | "mention" | "infraction" — see NOTIFICATION_TYPES in lib/notifications.ts
  type      String
  body      String
  link      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

// A formal disciplinary entry against a member, distinct from MemberNote:
// visible to the subject themselves (not just staff), and always notifies
// them when filed.
model MemberInfraction {
  id        String   @id @default(cuid())
  // "MINOR" | "MAJOR" | "SEVERE" — see INFRACTION_SEVERITIES in lib/infractions.ts
  severity  String
  reason    String
  createdAt DateTime @default(now())

  subjectId String
  subject   User   @relation("InfractionSubject", fields: [subjectId], references: [id])
  issuerId   String?
  issuer     User?  @relation("InfractionIssuer", fields: [issuerId], references: [id])
  // Denormalized so the record survives the issuer's account being deleted.
  issuerName String @default("")

  @@index([subjectId])
}

model MemberNote {
  id        String   @id @default(cuid())
  body      String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  subjectId String
  subject   User   @relation("MemberNoteSubject", fields: [subjectId], references: [id])
  authorId  String
  author    User   @relation("MemberNoteAuthor", fields: [authorId], references: [id])
}

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique
  active    Boolean  @default(true)
  // Free-text label so staff can remember what a batch was minted for
  // ("winter recruitment", "MTF Nu-7 transfers").
  note      String   @default("")
  // How many registrations this code may back. 1 preserves the original
  // single-use behavior; higher values allow a shared batch code.
  maxUses   Int      @default(1)
  useCount  Int      @default(0)
  // Recorded when staff revoke a code, so the log explains itself later.
  revokedReason String @default("")
  createdAt DateTime @default(now())
  expiresAt DateTime?

  createdById String?
  createdBy   User?   @relation("InviteCodeCreator", fields: [createdById], references: [id])

  // First redeemer. Kept for the pre-existing one-to-one relation and the
  // "USED BY" display; the full list lives in `redemptions`.
  usedById String?  @unique
  usedBy   User?    @relation("InviteCodeUser", fields: [usedById], references: [id])

  redemptions InviteRedemption[]

  @@index([createdById])
}

// One row per registration backed by an invite code. Lets a multi-use code
// report exactly who it let in.
model InviteRedemption {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  inviteId String
  invite   InviteCode @relation(fields: [inviteId], references: [id])
  userId   String
  user     User       @relation("InviteRedemptionUser", fields: [userId], references: [id])

  @@index([inviteId])
  @@index([userId])
}

model Message {
  id          String   @id @default(cuid())
  subject     String
  body        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  // Root message id of the conversation this message belongs to. Set to the
  // message's own id for a thread-starting message; replies inherit the root's.
  threadId    String?

  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([threadId])
}

model ScpFile {
  id                String   @id @default(cuid())
  title             String
  body              String
  clearanceRequired Int
  classification    String   @default("Safe")
  createdAt         DateTime @default(now())
  // Null until the document is first edited. `revisionCount` counts stored
  // prior versions, so the UI can show "REV 3" without a join.
  updatedAt         DateTime?
  revisionCount     Int      @default(0)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model Broadcast {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime?
  revisionCount Int  @default(0)
  // Scheduling window. `publishAt` null (or in the past) means the directive
  // is live now; `expiresAt` null means it never stands down. Filtering is
  // done at query time rather than by a job, so a directive becomes visible
  // and disappears on its own without anything needing to run.
  publishAt DateTime?
  expiresAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([publishAt])
  @@index([expiresAt])
}

// Binary attachment stored directly in the database.
//
// Bytes live here rather than in object storage because the deployment has no
// blob store configured, and every attachment is deleted 14 days after upload
// — which caps how large the table can get. Reads filter on `expiresAt`, so an
// expired file stops being served the moment it lapses, whether or not the
// sweeper has physically removed the row yet.
model Attachment {
  id         String   @id @default(cuid())
  // "secure" (a secure-channel transmission) | "personnel" (a member dossier).
  // See ATTACHMENT_ENTITIES in lib/attachments.ts.
  entityType String
  entityId   String
  filename   String
  mimeType   String
  size       Int
  data       Bytes
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  uploaderId   String?
  uploader     User?   @relation("AttachmentUploader", fields: [uploaderId], references: [id])
  // Denormalized so the caption survives the uploader's account deletion.
  uploaderName String  @default("")

  @@index([entityType, entityId])
  @@index([expiresAt])
  @@index([uploaderId])
}

model ClearanceRequest {
  id              String    @id @default(cuid())
  requestedLevel  Int
  reason          String
  status          String    @default("pending")
  reviewNote      String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?

  userId       String
  user         User     @relation("ClearanceRequestUser", fields: [userId], references: [id])
  reviewedById String?
  reviewedBy   User?    @relation("ClearanceRequestReviewer", fields: [reviewedById], references: [id])
}

// Secure communications channel for L-5+ clearance. A single shared, encrypted-
// styled feed that only cleared personnel can read or post to.
model SecureMessage {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

// Single-row site configuration (id is always "singleton"). Controls the
// owner-triggered maintenance lockdown and its bypass access code.
model SiteConfig {
  id                 String  @id @default("singleton")
  maintenanceMode    Boolean @default(false)
  bypassCode         String  @default("")
  maintenanceMessage String  @default("")
}

model IncidentReport {
  id                String   @id @default(cuid())
  title             String
  location          String   @default("")
  body              String
  severity          String   @default("Minor")
  clearanceRequired Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime?
  revisionCount     Int      @default(0)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

// Immutable snapshot of a document taken immediately before an edit lands, so
// the archive can show what a file used to say and who changed it.
//
// Deliberately generic across ScpFile / IncidentReport / Broadcast: the three
// share title+body and differ only in a couple of metadata fields, which are
// stashed as JSON in `meta` rather than adding three near-identical tables.
model Revision {
  id         String   @id @default(cuid())
  // "scp" | "incident" | "broadcast" — see REVISION_ENTITIES in lib/revisions.ts
  entityType String
  entityId   String
  title      String
  body       String
  // JSON blob of the type-specific fields at snapshot time (classification,
  // severity, location, clearanceRequired).
  meta       String   @default("{}")
  // Optional note the editor left explaining the change.
  reason     String   @default("")
  createdAt  DateTime @default(now())

  editorId   String?
  editor     User?    @relation("RevisionEditor", fields: [editorId], references: [id])
  // Denormalized so the history survives the editor's account being deleted.
  editorName String   @default("")

  @@index([entityType, entityId, createdAt])
  @@index([editorId])
}

// Append-only record of privileged actions. Actor name and target name are
// denormalized because the log has to stay readable after the accounts it
// references are deleted.
model AuditLog {
  id         String   @id @default(cuid())
  // Dot-namespaced verb, e.g. "user.clearance.set" — see AUDIT_ACTIONS.
  action     String
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  actorName  String   @default("")
  targetType String   @default("")
  targetId   String   @default("")
  targetName String   @default("")
  // Human-readable one-line description rendered directly in the admin log.
  summary    String   @default("")
  ip         String   @default("")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([actorId])
  @@index([targetId])
}

// Throttling ledger for credential and invite-code guessing. One row per
// attempt; `key` scopes the bucket (e.g. "login:agent@foundation.scp",
// "invite:203.0.113.4"). Rows are pruned opportunistically once expired.
model AuthAttempt {
  id        String   @id @default(cuid())
  key       String
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([createdAt])
}
